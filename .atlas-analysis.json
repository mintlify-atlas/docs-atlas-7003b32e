  "keyFeatures": [
    "Multi-organization forest patrimony management with hierarchical levels (Nivel 2/3/4/5)",
    "Geospatial shapefile import and processing with background workers",
    "Biological asset measurement campaigns and observations",
    "Land use tracking and variation monitoring",
    "Role-based access control (RBAC) with CASL permissions",
    "Audit logging and analytics dashboards"
  ],
  "publicApiSurface": [
    "POST /api/auth/login - User authentication",
    "GET /api/auth/session - Get current session",
    "GET /api/organizations - List organizations",
    "POST /api/forest/patrimony - Create forest patrimony record",
    "POST /api/forest/geo/import - Import shapefile",
    "GET /api/forest/geo/jobs - List geo import jobs",
    "POST /api/assets/measurement-campaigns - Create measurement campaign",
    "GET /api/assets/measurement-observations - List observations",
    "POST /api/users - Create user",
    "GET /api/roles - List roles",
    "GET /api/audit - Audit log entries"
  ]
